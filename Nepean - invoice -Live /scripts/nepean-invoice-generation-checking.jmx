                </hashTree>
                <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="final_result_File-e2" enabled="true">
                  <stringProp name="BeanShellSampler.query">import java.io.*;

// --- CSV SAFE WRAPPER ---
String csv(String v) {
    if (v == null || v.trim().equals(&quot;&quot;)) v = &quot;-&quot;;

    // Remove newlines
    v = v.replace(&quot;\n&quot;, &quot; &quot;).replace(&quot;\r&quot;, &quot; &quot;);

    // Replace commas so CSV does not break
    v = v.replace(&quot;,&quot;, &quot;;&quot;);

    // Escape double quotes
    v = v.replace(&quot;\&quot;&quot;, &quot;\&quot;\&quot;&quot;);

    // Wrap in quotes always
    return &quot;\&quot;&quot; + v + &quot;\&quot;&quot;;
}

// --- FILE PATHS ---
String passFile = vars.get(&quot;resultFileName1&quot;);
String failFile = vars.get(&quot;resultFileName2&quot;);

File passDataFile = new File(passFile);
File failDataFile = new File(failFile);

// --- CREATE PASS HEADER ---
if (!passDataFile.exists()) {
    passDataFile.getParentFile().mkdirs();
    FileOutputStream f = new FileOutputStream(passDataFile, true);
    PrintStream p = new PrintStream(f);
    p.println(&quot;invoice_num,invoice_period,userName,shift_hours,act_billing_total,exp_billing_total,exp_sub_total,act_gst_total,exp_gst_total,act_inv_total,exp_invoice_total,testResult,ModComments,invoiceHolidayComments&quot;);
    p.close();
    f.close();
}

// --- CREATE FAIL HEADER ---
if (!failDataFile.exists()) {
    failDataFile.getParentFile().mkdirs();
    FileOutputStream f = new FileOutputStream(failDataFile, true);
    PrintStream p = new PrintStream(f);
    p.println(&quot;invoice_num,invoice_period,userName,shift_hours,act_billing_total,exp_billing_total,exp_sub_total,act_gst_total,exp_gst_total,act_inv_total,exp_invoice_total,testResult,validationError,ModComments,invoiceHolidayComments&quot;);
    p.close();
    f.close();
}

// --- READ JMETER VARIABLES ---
String display_invoice_no  = vars.get(&quot;display_invoice_no&quot;);
String invoice_period = vars.get(&quot;invoice_period&quot;);
String userName = vars.get(&quot;userName&quot;);
String noOfHours = vars.get(&quot;noOfHours&quot;);
String act_billing_total = vars.get(&quot;act_billing_total&quot;);
String exp_billing_total = vars.get(&quot;exp_billing_total&quot;);
String exp_sub_total = vars.get(&quot;exp_sub_total&quot;);
String act_gst_total = vars.get(&quot;act_gst_total&quot;);
String exp_gst_total = vars.get(&quot;exp_gst_total&quot;);
String act_inv_total = vars.get(&quot;act_inv_total&quot;);
String exp_invoice_total = vars.get(&quot;exp_invoice_total&quot;);
String testResult = vars.get(&quot;testResult&quot;);

String errorReason = vars.get(&quot;errorReason&quot;);
String modComments = vars.get(&quot;mod_comments&quot;);
String holidayComments = vars.get(&quot;invoiceHolidayComments&quot;);

// --- BUILD CSV LINE ---
StringBuilder line = new StringBuilder();

line.append(csv(display_invoice_no)).append(&quot;,&quot;)
    .append(csv(invoice_period)).append(&quot;,&quot;)
    .append(csv(userName)).append(&quot;,&quot;)
    .append(csv(noOfHours)).append(&quot;,&quot;)
    .append(csv(act_billing_total)).append(&quot;,&quot;)
    .append(csv(exp_billing_total)).append(&quot;,&quot;)
    .append(csv(exp_sub_total)).append(&quot;,&quot;)
    .append(csv(act_gst_total)).append(&quot;,&quot;)
    .append(csv(exp_gst_total)).append(&quot;,&quot;)
    .append(csv(act_inv_total)).append(&quot;,&quot;)
    .append(csv(exp_invoice_total)).append(&quot;,&quot;)
    .append(csv(testResult)).append(&quot;,&quot;);

// ---- ADD FAIL-SPECIFIC COLUMN (validationError) ----
if (!&quot;PASS&quot;.equals(testResult)) {
    line.append(csv(errorReason)).append(&quot;,&quot;);
} 

// ---- ADD COMMENTS ----
line.append(csv(modComments)).append(&quot;,&quot;)
    .append(csv(holidayComments));

// ---- WRITE TO FILE ----
FileOutputStream f;
PrintStream p;

if (&quot;PASS&quot;.equals(testResult)) {
    f = new FileOutputStream(passDataFile, true);
    p = new PrintStream(f);
    p.println(line.toString());
} else {
    f = new FileOutputStream(failDataFile, true);
    p = new PrintStream(f);
    p.println(line.toString());
}

p.close();
f.close();
</stringProp>
