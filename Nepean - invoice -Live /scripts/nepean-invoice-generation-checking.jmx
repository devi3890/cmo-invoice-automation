                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

var holidayNames = [];
var holidayDates = [];

for (var i = 0; i &lt; data.length; i++) {
    holidayNames.push(data[i].holiday_name);
    holidayDates.push(data[i].h_date);
}

// Store as JSON arrays (correct array format)
vars.put(&quot;holidayNames&quot;, JSON.stringify(holidayNames));
vars.put(&quot;holidayDates&quot;, JSON.stringify(holidayDates));

//log.info(&quot;holidayNames array: &quot; + JSON.stringify(holidayNames));
//log.info(&quot;holidayDates array: &quot; + JSON.stringify(holidayDates));

//log.info(&quot;holidayNames&quot;+holidayNames.length)
//log.info(&quot;holidayDates&quot;+holidayDates.length)



</stringProp>
