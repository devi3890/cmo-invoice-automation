                  <stringProp name="script">//getting number of generated invoices for the given paycycle month

var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];
var counter = data.length;
var invoiceIds = [];
var displayInvoiceNums = [];

for( i = 0; i &lt; data.length; i++) {
	
    var invoiceId = data[i]._id;
    invoiceIds.push(invoiceId);
    var display_invoice_no=data[i].display_invoice_no;
    displayInvoiceNums.push(display_invoice_no);
}

vars.put(&quot;counter&quot;,counter);
log.info(&quot;number of generated invoices---&quot; +counter);
//log.info(invoiceIds);
//log.info(displayInvoiceNums);</stringProp>
