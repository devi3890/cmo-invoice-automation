        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="Create pass/fail result files" enabled="true">
          <stringProp name="TestPlan.comments">//delete existing result file and creates new result file</stringProp>
          <stringProp name="BeanShellSampler.query">// Create result file 
import org.apache.jmeter.services.FileServer;

// Define the report file name
String fileName1 = &quot;${__TestPlanName}&quot; + &quot;-Pass_Results.csv&quot;; //.replace(&quot;.jmx&quot;,&quot;&quot;)
String fileName2 = &quot;${__TestPlanName}&quot; + &quot;-Fail_Results.csv&quot;;
 
//get path of current jmeter&apos;s script
String path = FileServer.getFileServer().getBaseDir();
 
//get the separator
String separator = File.separator;
 
//log.info(&quot;Path: &quot; + path);
//log.info(&quot;Path with separator: &quot; + path + separator);

String resultFileName1 = path + &quot;/../result/&quot; + fileName1.replace(&quot;.jmx&quot;,&quot;&quot;);
String resultFileName2 = path + &quot;/../result/&quot; + fileName2.replace(&quot;.jmx&quot;,&quot;&quot;);

File file1 = new File(resultFileName1);
File file2 = new File(resultFileName2);

// Delete the file if exist first

if (file1.delete() &amp;&amp; file2.delete()) {
	
	log.info(&quot;Files deleted successfully&quot;);
} else {
	log.info(&quot;Failed to delete the files&quot;);
}





vars.put(&quot;resultFileName1&quot;, resultFileName1);
vars.put(&quot;resultFileName2&quot;, resultFileName2);

</stringProp>
