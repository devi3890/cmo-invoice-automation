                <hashTree>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor-wpth" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;]

//getting start date and end date from getgeneratedInvData service

var startDate = data.invoice_start_date
vars.put(&quot;startDate&quot;,startDate);
//log.info(startDate)
var endDate = data.invoice_end_date
vars.put(&quot;endDate&quot;,endDate);
startDate = startDate.split(&quot;-&quot;);
endDate = endDate.split(&quot;-&quot;);
//2023-03-13
//01/07/2021

var from = new Date(startDate[0], parseInt(startDate[1])-1, startDate[2]);  // -1 because months are from 0 to 11
var to   = new Date(endDate[0], parseInt(endDate[1])-1, endDate[2]);//getting time in IST formate
var fromdate_time = from.getTime()




//getting tax rates and effective dates from invoice tax_settings service 


var effective_dates = vars.get(&quot;effectivedates&quot;).split(&quot;,&quot;);
var sup_tax_rates = vars.get(&quot;superTaxRates&quot;).split(&quot;,&quot;);




//********************setting dates and super tax rates as key value pair
var myObject = {};
var hocObject = {};
var hssObject = {};


for(var i = 0; i &lt; effective_dates.length ; i++)
{ 

	myObject[effective_dates[i]] = sup_tax_rates[i]
}


//log.info(&quot;myObject is&quot; +JSON.stringify(myObject))

//o/p---&gt;{&quot;01/10/2018&quot;:&quot;9.5&quot;,&quot;01/12/2019&quot;:&quot;9.5&quot;,&quot;01/07/2021&quot;:&quot;10&quot;,&quot;01/07/2022&quot;:&quot;10.5&quot;,&quot;27/03/2020&quot;:&quot;9.5&quot;}


// ************* function to remove duplicate elements*****************
 
    function removeDuplicates(effective_dates) {
        var unique = [];
        for(i=0; i &lt; effective_dates.length; i++){ 
            if(unique.indexOf(effective_dates[i]) === -1) { 
                unique.push(effective_dates[i]); 
            } 
        }
        return unique;
    }
 
effective_dates = removeDuplicates(effective_dates);
//log.info(&quot;effective dates without duplication&quot;+effective_dates);






//fromdate_time
var effective_date_time = []


function getTime(fromDate)
{
var dates  = [] 
var effective_time = []
for(var index =0; index &lt; fromDate.length ; index++){

var element = fromDate[index];
   var parts = element.split(&quot;/&quot;);
   var date= new Date(parts[2], parseInt(parts[1]) - 1, parts[0]);
   dates.push(date);
   effective_time.push(dates[index].getTime())
}
return effective_time
}

effective_date_time  = getTime(effective_dates)


//log.info(&quot;without ascending order&quot;+effective_date_time)
//log.info(&quot;without hoc_ascending order^^^^^^^^^^^^^^^^^&quot;+hoc_effective_date_time)
//log.info(&quot;without hss_ascending order&quot;+hss_effective_date_time)

//o/p---&gt;1538332200000,1575138600000,1625077800000,1656613800000,1585247400000
//log.info(effective_date_time[0])






//*********************copying effective_date_time to sdate
var sdate = []

function pushArray(arr, arr2) {
 return arr.push.apply(arr, arr2);
 
}
var sodate = pushArray(sdate, effective_date_time);

//log.info(&quot;shocdate ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^&quot;+shocdate)
//log.info(&quot;sodate&quot;+sodate)
//o/p---&gt; 5



//********* arranging dates in ascending order

function bubbleSort(effective_date_time) {
  var done = false;
  while (!done) {
    done = true;
    for (var i = 1; i &lt; effective_date_time.length; i += 1) {
      if (effective_date_time[i - 1] &lt; effective_date_time[i]) {
        done = false;
        var tmp = effective_date_time[i - 1];
        effective_date_time[i - 1] = effective_date_time[i];
        effective_date_time[i] = tmp;
      }
    }
  }

  return effective_date_time;
}

var sorted_dates = bubbleSort(effective_date_time)
//log.info(&quot;dates in order is &quot; +sorted_dates)


//o/p-----&gt;1656613800000,1625077800000,1585247400000,1575138600000,1538332200000


//*********************compare super patient seen effective dates
var flag = 0;
var super_tax_rate;
for (var index = 0 ; index &lt;  sorted_dates.length; index++) {
   
   
    if ((fromdate_time &gt; sorted_dates[index] || fromdate_time === sorted_dates[index]) &amp;&amp; flag === 0) {

          flag = 1
    	     for (var i = 0; i &lt; effective_date_time.length; i++)
    	     {
    	 	if(sdate[i] === sorted_dates[index])
          {
          	
    	 	super_tax_rate = myObject[effective_dates[i]]
    	 	
        }
}

}

}
vars.put(&quot;super_tax_rate&quot;,super_tax_rate);
log.info(&quot;super tax rate is&quot;+super_tax_rate)


</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

var invoice_summary = data.invoice_summary
var act_billing_total = invoice_summary.billing_total
vars.put(&quot;act_billing_total&quot;,act_billing_total)

var act_super_annonation = invoice_summary.super_annonation
vars.put(&quot;act_super_annonation&quot;,act_super_annonation)
//log.info(&quot;act_super_annonation is...&quot;+act_super_annonation)
var act_gst_total = invoice_summary.gst_total
vars.put(&quot;act_gst_total&quot;,act_gst_total)
//log.info(&quot;act_gst_total is...&quot;+act_gst_total)
var act_inv_total = invoice_summary.inv_total
vars.put(&quot;act_inv_total&quot;,act_inv_total)
//log.info(&quot;act_inv_total is...&quot;+act_inv_total)
var discount_percentage = data.discount_percentage
vars.put(&quot;discount_percentage&quot;,discount_percentage)
//log.info(&quot;discount_percentage is...&quot;+discount_percentage)
var credit_invoice = data.credit_note_invoice_id
var is_credit_note = false
var invoice_period = data.invoice_period
vars.put(&quot;invoice_period&quot;,invoice_period)
//log.info(&quot;invoice_period is.....&quot; +invoice_period)
var display_invoice_no = data.display_invoice_no
vars.put(&quot;display_invoice_no&quot;,display_invoice_no)
//log.info(&quot;invoice_period is...&quot;+invoice_period)
var noOfHours = data.display_total_hrs  
vars.put(&quot;noOfHours&quot;,noOfHours)

if(credit_invoice &gt; 0)
{
	is_credit_note = true
}
vars.put(&quot;is_credit_note&quot;,is_credit_note)

//log.info(&quot;credit note is&quot; +is_credit_note)
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                </hashTree>
                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="shiftinformation-${invoiceId}" enabled="true">
                  <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                    <collectionProp name="Arguments.arguments">
                      <elementProp name="" elementType="HTTPArgument">
                        <boolProp name="HTTPArgument.always_encode">false</boolProp>
                        <stringProp name="Argument.value">{&#xd;
  &quot;invoice_id&quot;: &quot;${invoiceId}&quot;,&#xd;
  &quot;hid&quot;: 106,&#xd;
  &quot;decimalCalObj&quot;: {&#xd;
    &quot;hid&quot;: 106,&#xd;
    &quot;isRoundOff&quot;: 1,&#xd;
    &quot;decimalCnt&quot;: 2,&#xd;
    &quot;displayDecimalCnt&quot;: 2,&#xd;
    &quot;display_sign_off&quot;: 1&#xd;
  }&#xd;
}</stringProp>
                        <stringProp name="Argument.metadata">=</stringProp>
                      </elementProp>
                    </collectionProp>
                  </elementProp>
                  <stringProp name="HTTPSampler.domain"></stringProp>
