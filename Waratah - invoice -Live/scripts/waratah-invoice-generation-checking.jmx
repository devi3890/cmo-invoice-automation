              <hashTree>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="superTax_with_efective_dates_patientseensessional_onsite" enabled="true">
                  <stringProp name="scriptLanguage">javascript</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">// getting super tax rates with effective dates for patient seen sessional and for haematologist oncall and onsite

var response = JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;];


var effectivedates = []
var superTaxRates = []
var effectivedatesSessional = []
var superTaxRatesSessional = []


for(var i = 0; i&lt;data.length; i++){


var sup = data[i].tax_name

var tax_name = sup.toLowerCase()

 
  if(data[i].sub_servicename == &quot;Med Roster&quot; &amp;&amp; tax_name == &quot;super&quot; || tax_name == &quot;Superannuation&quot; || tax_name == &quot;superannuation&quot;&amp;&amp; data[i].invoicing_service == 1)   {

  	
  	
  	effectivedates.push(data[i].display_effective_date)
  	superTaxRates.push(data[i].tax_rate)
  }   
	
}


vars.put(&quot;effectivedates&quot;,effectivedates);
vars.put(&quot;superTaxRates&quot;,superTaxRates);



log.info(&quot;superTaxRate effectivedates is....&quot;+effectivedates)
log.info(&quot;superTaxRates is....&quot;+superTaxRates)



</stringProp>
                  <stringProp name="TestPlan.comments">// tax_settings sampler getting super, gst, nsw, cpi tax rates with effective dates in response</stringProp>
                </JSR223PostProcessor>
                <hashTree/>
              </hashTree>
              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="get_superannuation_rule" enabled="true">
                <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
