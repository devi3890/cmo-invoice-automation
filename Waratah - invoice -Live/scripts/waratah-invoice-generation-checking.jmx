              <hashTree>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="super_eligible_in_meetings and teachings" enabled="true">
                  <stringProp name="scriptLanguage">javascript</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var data = response.data || [];

var sup_eligible_role = [];

for (var i = 0; i &lt; data.length; i++) {

    var role = data[i];

    // Only Med Roster exists for this hospital
    if (role.sub_servicename !== &quot;Med Roster&quot;) {
        continue;
    }

    // If super_allowed has components → SUPER eligible
    if (role.super_allowed &amp;&amp; role.super_allowed.length &gt; 0) {

        if (sup_eligible_role.indexOf(role.role_name) === -1) {
            sup_eligible_role.push(role.role_name);
        }
    }
}

// Store as CSV for reuse
vars.put(&quot;sup_eligible_role&quot;, sup_eligible_role.join(&quot;,&quot;));

//log.info(&quot;sup_eligible_role is&quot;+sup_eligible_role)

log.info(&quot;Super Eligible Roles (Med Roster): &quot; + sup_eligible_role.join(&quot;,&quot;));
</stringProp>
                  <stringProp name="TestPlan.comments">//http sampler getting roles which are eligible for super in meetings and teachings</stringProp>
                </JSR223PostProcessor>
