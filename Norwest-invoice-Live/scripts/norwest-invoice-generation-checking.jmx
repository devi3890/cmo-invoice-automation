                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">//*******getting user roles and role ids
//************* for eg:: Anasthetist role id :: 50
var response = JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;]
var jobRoles = data.length;
var role_name = [];
var role_id = [];


//Aneasthetist------&gt; rolecode:::50

for(var i = 0; i &lt; jobRoles; i++)
{
	role_id.push(data[i].role_id);
	role_name.push(data[i].role_name);
}

vars.put(&quot;role_id&quot;,role_id)
vars.put(&quot;role_name&quot;,role_name)

//log.info(&quot;role_id is&quot; +role_id)

//log.info(&quot;role_name is&quot; +role_name)
</stringProp>
