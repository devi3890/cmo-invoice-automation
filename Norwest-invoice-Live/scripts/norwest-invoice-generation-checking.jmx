                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="getting-rates" enabled="true">
                  <stringProp name="scriptLanguage">javascript</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var ratesAPIOBJ = response[&quot;data&quot;];

// ✅ convert object → string before storing in vars
vars.put(&quot;ratesAPIOBJ&quot;, JSON.stringify(ratesAPIOBJ));

//log.info(&quot;ratesAPIOBJ is.. &quot; + JSON.stringify(ratesAPIOBJ));

</stringProp>
                </JSR223PostProcessor>
                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="getting-rates" enabled="false">
                  <stringProp name="scriptLanguage">javascript</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());

// ❗ your API gives array directly
var rateData = response;

var rateMap = {};

// helper
function dayTypeFromDay(dayNum) {
    if (dayNum === 6 || dayNum === 7) return &quot;weekend&quot;;
    return &quot;weekday&quot;;
}

for (var i = 0; i &lt; rateData.length; i++) {

    var hospitalName = rateData[i].hospital_name;   // if available
    var wardName     = rateData[i].ward_name;       // if available
    var roleName     = rateData[i].role_name;       // if available
    var shiftName    = rateData[i].shift_name;

    var fromTime     = rateData[i].from_time;
    var toTime       = rateData[i].to_time;

    log.info(&quot;Processing shift: &quot; + shiftName);

    // Day 1 → Day 7 rates
    for (var day = 1; day &lt;= 7; day++) {

        var rate = rateData[i][&quot;day&quot; + day + &quot;_rate&quot;];

        var key =
            hospitalName + &quot;|&quot; +
            wardName + &quot;|&quot; +
            roleName + &quot;|&quot; +
            shiftName + &quot;|&quot; +
            dayTypeFromDay(day) + &quot;|&quot; +
            fromTime + &quot;-&quot; + toTime;

        rateMap[key] = rate;
    }

    // PH rate
    var phKey =
        hospitalName + &quot;|&quot; +
        wardName + &quot;|&quot; +
        roleName + &quot;|&quot; +
        shiftName + &quot;|&quot; +
        &quot;ph&quot; + &quot;|&quot; +
        fromTime + &quot;-&quot; + toTime;

    rateMap[phKey] = rateData[i].ph_rate;
}

// store once
vars.put(&quot;RATE_MAP&quot;, JSON.stringify(rateMap));
log.info(&quot;RATE_MAP =&gt; &quot; + JSON.stringify(rateMap));



</stringProp>
                </JSR223PostProcessor>
