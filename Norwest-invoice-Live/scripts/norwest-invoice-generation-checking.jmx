              <hashTree>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
                  <stringProp name="scriptLanguage">javascript</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;]
var paycycleperiod = data.payCyclePeriod

var paycycleStartDate
var paycycleEndDate

for (var i = 0; i &lt; paycycleperiod.length; i++) {

    if (paycycleperiod[i].selectvalue == 1) {

        paycycleStartDate = paycycleperiod[i-1].start_date
        paycycleEndDate = paycycleperiod[i-1].end_date
    }
}

vars.put(&quot;paycycleStartDate&quot;,paycycleStartDate)
vars.put(&quot;paycycleEndDate&quot;,paycycleEndDate)
log.info(&quot;paycycleStartDate is..&quot;+paycycleStartDate)
log.info(&quot;paycycleEndDate is..&quot;+paycycleEndDate)



// 🔥 Convert dd/MM/yyyy → yyyy-MM-dd
function formatDate(dateStr) {
    var parts = dateStr.split(&quot;/&quot;)
    return parts[2] + &quot;-&quot; + parts[1] + &quot;-&quot; + parts[0]
}

var formattedStartDate = formatDate(paycycleStartDate)
var formattedEndDate = formatDate(paycycleEndDate)

log.info(&quot;Start Date: &quot; + formattedStartDate)
log.info(&quot;End Date: &quot; + formattedEndDate)


vars.put(&quot;invoice_start_date&quot;, formattedStartDate)
vars.put(&quot;invoice_end_date&quot;, formattedEndDate)

</stringProp>
                </JSR223PostProcessor>
