                <hashTree>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Cmo onsite calculations-chatgpt-get rates for the shifts including spl rate" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/*************************************************************
 * RATE ENGINE – FINAL VERSION (JMETER / NASHORN SAFE)
 * OUTPUT:
 *   rateKeyMap = {
 *     &quot;ICU | 20/01/2026 | SC-D12.5 | 07:00 - 19:30&quot;: 155,
 *     ...
 *   }
 *************************************************************/

/* ============================
   PARSE RESPONSE
   ============================ */
var response = JSON.parse(prev.getResponseDataAsString());
var data     = response.data || {};
var shifts   = data.invoice_generation_shifts || [];

/* ============================
   READ SUPPORTING DATA
   ============================ */
var ratesAPIOBJ   = JSON.parse(vars.get(&quot;ratesAPIOBJ&quot;) || &quot;[]&quot;);
var holidayDates  = JSON.parse(vars.get(&quot;holidayDates&quot;) || &quot;[]&quot;);

/* ============================
   BASIC HELPERS (NASHORN SAFE)
   ============================ */
function pad2(n) {
    return (n &lt; 10 ? &quot;0&quot; : &quot;&quot;) + n;
}

function toDate(d) {
    return new Date(d + &quot;T00:00:00&quot;);
}

function formatDDMMYYYY(dateStr) {
    var d = toDate(dateStr);
    return pad2(d.getDate()) + &quot;/&quot; + pad2(d.getMonth() + 1) + &quot;/&quot; + d.getFullYear();
}

function formatTime(mins) {
    var h = Math.floor(mins / 60);
    var m = mins % 60;
    return pad2(h) + &quot;:&quot; + pad2(m);
}

function isHoliday(dateObj) {
    return holidayDates.indexOf(
        dateObj.getFullYear() + &quot;-&quot; +
        pad2(dateObj.getMonth() + 1) + &quot;-&quot; +
        pad2(dateObj.getDate())
    ) !== -1;
}

function isCustomShift(shift) {
    return shift.shift_name === &quot;C&quot;; // Segment
}

/* ============================
   SLOT DATE RESOLUTION
   ============================ */
function resolveSlotDate(shiftDate, fromMin, toMin) {

    var d = toDate(shiftDate);

    // 00:00–07:00 → previous day
    if (fromMin &lt; 420 &amp;&amp; toMin &lt;= 420) {
        d.setDate(d.getDate() - 1);
        return d;
    }

    // Cross midnight
    if (fromMin &gt; toMin) {
        d.setDate(d.getDate() + 1);
        return d;
    }

    return d;
}

/* ============================
   DAY / HOLIDAY RATE
   ============================ */
function getDayRate(hourlyRate, shift, slotFrom, slotTo) {

    var rateDate = isCustomShift(shift)
        ? resolveSlotDate(shift.shift_start_date, slotFrom, slotTo)
        : toDate(shift.shift_start_date);

    if (isHoliday(rateDate)) {
        return Number(hourlyRate.ph_rate) || 0;
    }

    switch (rateDate.getDay()) {
        case 1: return Number(hourlyRate.day1_rate) || 0;
        case 2: return Number(hourlyRate.day2_rate) || 0;
        case 3: return Number(hourlyRate.day3_rate) || 0;
        case 4: return Number(hourlyRate.day4_rate) || 0;
        case 5: return Number(hourlyRate.day5_rate) || 0;
        case 6: return Number(hourlyRate.day6_rate) || 0;
        case 0: return Number(hourlyRate.day7_rate) || 0;
        default: return 0;
    }
}

/* ============================
   SLOT TIME
   ============================ */
function getSlotTime(hourlyRate, shift) {

    if (isCustomShift(shift)) {
        var slot = JSON.parse(hourlyRate.slot_timings || &quot;{}&quot;);
        return { from: Number(slot.start_time), to: Number(slot.end_time) };
    }

    return { from: Number(hourlyRate.from_time), to: Number(hourlyRate.to_time) };
}

/* ============================
   TIME MATCHING
   ============================ */
function isTimeMatching(hourlyRate, shift) {

    if (isCustomShift(shift)) return true;

    var shiftStart = Number(shift.start_time);
    var shiftEnd   = Number(shift.end_time);

    var slot = getSlotTime(hourlyRate, shift);
    var rateFrom = slot.from;
    var rateTo   = slot.to;

    var shiftNight = shiftStart &gt; shiftEnd;
    var rateNight  = rateFrom &gt; rateTo;

    if (shiftNight) {
        if (!rateNight) return false;
        return shiftStart &gt;= rateFrom || shiftEnd &lt;= rateTo;
    } else {
        if (rateNight) return false;
        return shiftStart &gt;= rateFrom &amp;&amp; shiftEnd &lt;= rateTo;
    }
}

/* ============================
   DOCTOR → COMMON RATE FILTER
   ============================ */
function getApplicableRates(shift, rates) {

    var doctorRates = [];
    var commonRates = [];

    for (var i = 0; i &lt; rates.length; i++) {

        var r = rates[i];

        if (
            r.subservice_name !== shift.sub_service_name ||
            r.ward_name !== shift.ward_name
        ) continue;

        if (
            r.name &amp;&amp;
            r.name.toUpperCase() === shift.shift_doctor_name.toUpperCase()
        ) {
            doctorRates.push(r);
        } else if (!r.name || r.name.trim() === &quot;&quot;) {
            commonRates.push(r);
        }
    }

    return doctorRates.length &gt; 0 ? doctorRates : commonRates;
}

/* ============================
   FIND FINAL RATE
   ============================ */
function findFinalRate(rateObjs, shift) {

    var requiredRateType = isCustomShift(shift) ? 3 : 1;

    for (var i = 0; i &lt; rateObjs.length; i++) {

        var rateObj = rateObjs[i];
        if (rateObj.rate_type !== requiredRateType) continue;

        var hrs = rateObj.hourly_rates || [];

        for (var j = 0; j &lt; hrs.length; j++) {

            var hr = hrs[j];
            if (!isTimeMatching(hr, shift)) continue;

            var slot = getSlotTime(hr, shift);
            var rate = getDayRate(hr, shift, slot.from, slot.to);

            if (rate &gt; 0) return rate;
        }
    }
    return 0;
}

/* ============================
   BUILD RATE KEY
   ============================ */
function buildRateKey(shift) {

    return (
        shift.ward_name + &quot; | &quot; +
        formatDDMMYYYY(shift.shift_start_date) + &quot; | &quot; +
        (isCustomShift(shift) ? &quot;C&quot; : shift.shift_name) + &quot; | &quot; +
        formatTime(Number(shift.start_time)) + &quot; - &quot; +
        formatTime(Number(shift.end_time))
    );
}

/* ============================
   MAIN EXECUTION
   ============================ */
var rateKeyMap = {};

for (var i = 0; i &lt; shifts.length; i++) {

    var shift = shifts[i];
    var finalRate = 0;
    var rateSource = &quot;&quot;;

    // 🥇 SPECIAL RATE
    if (
        Number(shift.shift_rate_type) === 3 &amp;&amp;
        Number(shift.shift_rate) &gt; 0
    ) {
        finalRate = Number(shift.shift_rate);
        rateSource = &quot;SPECIAL RATE (SHIFT API)&quot;;
    } else {

        var applicableRates = getApplicableRates(shift, ratesAPIOBJ);
        if (applicableRates.length === 0) continue;

        finalRate = findFinalRate(applicableRates, shift);
        if (finalRate === 0) continue;

        rateSource = &quot;RATE CONFIG (DOCTOR / WARD)&quot;;
    }

    var key = buildRateKey(shift);
    rateKeyMap[key] = finalRate;

    //log.info(
       // &quot;[RATE ENGINE] Key=&quot; + key +
      //  &quot; | Rate=&quot; + finalRate +
      //  &quot; | Source=&quot; + rateSource
   // );
}

/* ============================
   STORE FOR NEXT PROCESSOR
   ============================ */
   
vars.put(&quot;rateKeyMap&quot;, JSON.stringify(rateKeyMap));

log.info(&quot;✅ RATE KEY MAP GENERATED: &quot; + JSON.stringify(rateKeyMap));
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Cmo onsite calculations-validate API AND UI(DISPLAY) rates" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">/*************************************************************
 * RATE ENGINE + DISPLAY RATE VALIDATION (CONTROLLED)
 * JMeter | Nashorn Safe
 *************************************************************/

/* ============================
   INIT FLAGS (DEFAULT)
   ============================ */
vars.put(&quot;rateMismatchFlag&quot;, &quot;FALSE&quot;);
vars.put(&quot;rateMismatchReason&quot;, &quot;&quot;);

/* ============================
   PARSE RESPONSE
   ============================ */
var response = JSON.parse(prev.getResponseDataAsString());
var data     = response.data || {};
var shifts   = data.invoice_generation_shifts || [];
var shiftCount = shifts.length;

/* ============================
   READ STORED RATE MAP
   ============================ */
var rateKeyMap = JSON.parse(vars.get(&quot;rateKeyMap&quot;) || &quot;{}&quot;);

/* ============================
   HELPERS
   ============================ */
function splitByBrOrNewLine(value) {
    if (!value) return [];
    value = String(value);
    if (value.indexOf(&quot;&lt;br&gt;&quot;) !== -1) return value.split(&quot;&lt;br&gt;&quot;);
    return value.split(&quot;\n&quot;);
}

/* ============================
   NORMALIZE DISPLAY TITLE
   ============================ */
function normalizeDisplayTitles(titleArr) {

    var result = [];

    for (var i = 0; i &lt; titleArr.length; i++) {

        var line = titleArr[i].trim();

        if (line.indexOf(&quot;,&quot;) !== -1) {
            result.push(line);
        } else if (
            i + 1 &lt; titleArr.length &amp;&amp;
            titleArr[i + 1].indexOf(&quot;-&quot;) !== -1
        ) {
            result.push(line + &quot;,&quot; + titleArr[i + 1].trim());
            i++;
        }
    }
    return result;
}

/* ============================
   BUILD RATE KEY
   ============================ */
function buildRateKeyFromDisplay(shift, displayTitle) {

    var parts = displayTitle.split(&quot;,&quot;);
    if (parts.length &lt; 2) return null;

    var datePart = parts[0].split(&quot;-&quot;)[1].trim();
    var shiftAndTime = parts[1].trim();

    var idx = shiftAndTime.indexOf(&quot; - &quot;);
    if (idx === -1) return null;

    var shiftCode = shiftAndTime.substring(0, idx).trim();
    var timePart  = shiftAndTime.substring(idx + 3).trim();

    return (
        shift.ward_name + &quot; | &quot; +
        datePart + &quot; | &quot; +
        shiftCode + &quot; | &quot; +
        timePart
    );
}

/* ============================
   MED ROSTER CHECK
   ============================ */
function isMedRoster(sub) {
    return sub === &quot;Med Roster&quot;;
}

/* ============================
   MAIN VALIDATION
   ============================ */
if (shiftCount &gt; 0) {

    log.info(&quot;🔍 Validating Display Rate vs Engine Rate&quot;);

    outer:
    for (var i = 0; i &lt; shiftCount; i++) {

        var shift = shifts[i];
        if (!isMedRoster(shift.sub_service_name)) continue;

        var titleArr = splitByBrOrNewLine(shift.display_title);
        var rateArr  = splitByBrOrNewLine(shift.display_applied_rate);

        var normalizedTitles = normalizeDisplayTitles(titleArr);

        for (var j = 0; j &lt; normalizedTitles.length; j++) {

            var displayTitle = normalizedTitles[j];
            var displayRate  = Number(rateArr[j]);

            var rateKey = buildRateKeyFromDisplay(shift, displayTitle);

            if (!rateKey || rateKeyMap[rateKey] === undefined) {

                vars.put(&quot;rateMismatchFlag&quot;, &quot;TRUE&quot;);
                vars.put(
                    &quot;rateMismatchReason&quot;,
                    &quot;RATE KEY NOT FOUND : &quot; + rateKey
                );

                log.error(&quot;❌ RATE KEY NOT FOUND: &quot; + rateKey);
                break outer;
            }

            var engineRate = Number(rateKeyMap[rateKey]);

            if (Math.abs(engineRate - displayRate) &gt; 0.01) {

                vars.put(&quot;rateMismatchFlag&quot;, &quot;TRUE&quot;);
                vars.put(
                    &quot;rateMismatchReason&quot;,
                    &quot;RATE MISMATCH  &quot; + rateKey +
                    &quot; | Engine=&quot; + engineRate +
                    &quot; | UI=&quot; + displayRate
                );

                log.error(
                    &quot;❌ RATE MISMATCH  &quot; +
                    &quot;Key=&quot; + rateKey +
                    &quot; Engine=&quot; + engineRate +
                    &quot; UI=&quot; + displayRate
                );

                break outer;
            }

            log.info(&quot;✅ RATE MATCHED  &quot; + rateKey);
        }
    }
}
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Cmo onsite calculations-chatgpt-added validation for rate 0 -new chatgpt working version e1" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// ---------- CHECK RATE MISMATCH FLAG FIRST ----------
var rateMismatchFlag = vars.get(&quot;rateMismatchFlag&quot;) || &quot;FALSE&quot;;
var rateMismatchReason = vars.get(&quot;rateMismatchReason&quot;) || &quot;&quot;;

if (rateMismatchFlag === &quot;TRUE&quot;) {
    log.info(&quot;⚠️ Rate mismatch detected earlier: &quot; + rateMismatchReason);
    vars.put(&quot;onsiteErrorFlag&quot;, &quot;TRUE&quot;);
    vars.put(&quot;onsiteErrorReason&quot;, rateMismatchReason);

} else {

    // ---------- PARSE RESPONSE ----------
    var response = JSON.parse(prev.getResponseDataAsString());
    var data = response.data || {};
    var shifts = data.invoice_generation_shifts || [];
    var shiftCount = shifts.length;

    log.info(&quot;---------- ONSITE CALCULATION START ----------&quot;);
    log.info(&quot;Number of Med roster shifts: &quot; + shiftCount);

    // ---------- COMMON VARIABLES ----------
    var totalAmount = 0;
    var actualGST = 0;
    var totSplitAmt = 0;
    var totSplitAmtExcludePvt = 0;
    var displayShiftAmt = 0;
    var displayGST = 0;
    var displayTotal = 0;

    var gst = Number(vars.get(&quot;gst&quot;));

    // ---------- HELPER FUNCTIONS ----------
    function splitByBrOrNewLine(value) {
        if (!value) return [];
        value = String(value);
        return value.indexOf(&quot;&lt;br&gt;&quot;) !== -1 ? value.split(&quot;&lt;br&gt;&quot;) : value.split(&quot;\n&quot;);
    }

    function isMedRoster(sub, ward) {
        return sub === &quot;Med Roster&quot; &amp;&amp;
               (ward === &quot;Surgical CMO&quot; || ward === &quot;ICU&quot; || ward === &quot;CCU/ICU/WH&quot;);
    }

    // ---------- HOLIDAY CHECK ----------
    var holidayNames = JSON.parse(vars.get(&quot;holidayNames&quot;) || &quot;[]&quot;);
    var holidayDates = JSON.parse(vars.get(&quot;holidayDates&quot;) || &quot;[]&quot;);

    var invoiceHolidayComments = &quot;&quot;;

    for (var h = 0; h &lt; shiftCount; h++) {
        var idx = holidayDates.indexOf(shifts[h].shift_start_date);
        if (idx !== -1) {
            invoiceHolidayComments +=
                &quot;Shift on &quot; + shifts[h].shift_start_date +
                &quot; is Holiday: &quot; + holidayNames[idx] + &quot;. &quot;;

            log.info(&quot;HOLIDAY FOUND: &quot; +
                     shifts[h].shift_start_date + &quot; → &quot; + holidayNames[idx]);
        }
    }
    vars.put(&quot;invoiceHolidayComments&quot;, invoiceHolidayComments);

    // ---------- MAIN SHIFT LOOP ----------
    var rateZeroComments = &quot;&quot;;
    var rateZeroKeys = [];

    for (var i = 0; i &lt; shiftCount; i++) {

        var shift = shifts[i];
        if (!isMedRoster(shift.sub_service_name, shift.ward_name)) continue;

        log.info(&quot;Processing shift index: &quot; + i);
        log.info(&quot;Ward: &quot; + shift.ward_name +
                 &quot;, Date: &quot; + shift.shift_start_date +
                 &quot;, Code: &quot; + shift.shift_code);

        // UI display values
        displayShiftAmt += shift.shift_amt_wo_gst;
        displayGST += Number(shift.display_total_shift_gst_amt);
        displayTotal += shift.total_shift_amt;

        log.info(&quot;UI shift amount (wo gst): &quot; + shift.shift_amt_wo_gst);
        log.info(&quot;UI shift gst amount: &quot; + shift.display_total_shift_gst_amt);
        log.info(&quot;UI total shift amount: &quot; + shift.total_shift_amt);

        var timings = splitByBrOrNewLine(shift.display_shift_timings);
        var rates = splitByBrOrNewLine(shift.display_applied_rate);

        var splitCount = timings.length;
        var totalHours = shift.total_hrs / 60;
        var pvtHours = Number(shift.pvt_hrs);

        log.info(&quot;totalHours are.. &quot; + totalHours);
        log.info(&quot;splitCount is.. &quot; + splitCount);
        log.info(&quot;private hours are.. &quot; + pvtHours);

        // ---------- RATE ZERO CHECK ----------
        for (var r = 0; r &lt; rates.length; r++) {
            var uiRate = Number(rates[r]);
            var rateKey = shift.ward_name + &quot; | &quot; +
                          shift.shift_start_date + &quot; | &quot; +
                          shift.shift_code + &quot; | &quot; +
                          timings[r];

            if (uiRate === 0) {
                log.info(&quot;⚠️ Rate became ZERO for split &quot; + (r + 1));
                log.info(&quot;Rate ZERO key: &quot; + rateKey);

                rateZeroComments += &quot;Rate ZERO for &quot; + rateKey + &quot;. &quot;;
                rateZeroKeys.push(rateKey);
            }
        }

        // ---------- AMOUNT CALCULATION ----------
        if (splitCount &gt; 1 &amp;&amp; pvtHours === 0) {

            log.info(&quot;block one: Split shift + No private hrs - split exists&quot;);

            for (var j = 0; j &lt; splitCount; j++) {
                var t = timings[j].split(&quot; - &quot;);
                var f = t[0].split(&quot;:&quot;);
                var to = t[1].split(&quot;:&quot;);

                var fromMin = Number(f[0]) * 60 + Number(f[1]);
                var toMin = Number(to[0]) * 60 + Number(to[1]);
                var hrs = (toMin - fromMin) / 60;

                var amt = hrs * Number(rates[j]);
                totSplitAmt += amt;

                log.info(&quot;split_shift_amt is &quot; + amt);
                log.info(&quot;tot_split_shift_onSiteAmount is &quot; + totSplitAmt);
            }

        } else if (splitCount &gt; 1 &amp;&amp; pvtHours !== 0) {

            log.info(&quot;block two: Split shift + Private hrs&quot;);

            var amt2 = Number(rates[0]) * totalHours;
            totSplitAmtExcludePvt += amt2;

            log.info(&quot;split_shift_amt_excluded_pvt is &quot; + amt2);
            log.info(&quot;total_excluded_pvt is &quot; + totSplitAmtExcludePvt);

        } else {

            log.info(&quot;Single shift calculation&quot;);

            var amount = Number(shift.display_applied_rate) * totalHours;
            totalAmount += amount;

            log.info(&quot;single shift amount is &quot; + amount);
        }
    }

    // ---------- RATE ZERO SAVE ----------
    if (rateZeroComments) {
        log.info(&quot;RATE ZERO COMMENT: &quot; + rateZeroComments);
        vars.put(&quot;onsiteRateZeroComment&quot;, rateZeroComments);
        vars.put(&quot;onsiteRateZeroKeys&quot;, JSON.stringify(rateZeroKeys));
    }

    // ---------- GST CALCULATION ----------
    var preGSTAmount = totSplitAmt + totSplitAmtExcludePvt + totalAmount;
    log.info(&quot;preGSTAmount is &quot; + preGSTAmount);

    if (gst === 1) {
        actualGST = (preGSTAmount * 10) / 100;
        log.info(&quot;user is gst registered - gst tax calculated &quot; + actualGST);
    } else {
        log.info(&quot;user is NOT gst registered&quot;);
    }

    var onsiteTotal = preGSTAmount;
    var onsiteInvoiceTotal = onsiteTotal + actualGST;

    // ---------- FINAL TOTAL LOGS ----------
    log.info(&quot;Calculated onsite total (excl gst): &quot; + onsiteTotal);
    log.info(&quot;Calculated GST: &quot; + actualGST);
    log.info(&quot;Calculated onsite invoice total: &quot; + onsiteInvoiceTotal);

    log.info(&quot;UI display shift total: &quot; + displayShiftAmt);
    log.info(&quot;UI display gst total: &quot; + displayGST);
    log.info(&quot;UI display invoice total: &quot; + displayTotal);

    // ---------- STANDARD VALIDATION ----------
    var errorFlag = &quot;FALSE&quot;;
    var errorReason = &quot;&quot;;

    log.info(&quot;Shift diff is: &quot; + Math.abs(onsiteTotal - displayShiftAmt));
    log.info(&quot;GST diff is: &quot; + Math.abs(displayGST - actualGST));
    log.info(&quot;Invoice diff is: &quot; + Math.abs(displayTotal - onsiteInvoiceTotal));

    if (rateZeroComments) {
        errorFlag = &quot;TRUE&quot;;
        errorReason = &quot;Rate ZERO&quot;;
    } else if (Math.abs(onsiteTotal - displayShiftAmt) &gt; 0.8) {
        errorFlag = &quot;TRUE&quot;;
        errorReason = &quot;Shift Amount Mismatch&quot;;
    } else if (Math.abs(displayGST - actualGST) &gt; 0.8) {
        errorFlag = &quot;TRUE&quot;;
        errorReason = &quot;GST Mismatch&quot;;
    } else if (Math.abs(displayTotal - onsiteInvoiceTotal) &gt; 0.8) {
        errorFlag = &quot;TRUE&quot;;
        errorReason = &quot;Invoice Total Mismatch&quot;;
    }

    log.info(&quot;Final Error Flag: &quot; + errorFlag);
    log.info(&quot;Final Error Reason: &quot; + errorReason);

    // ---------- PUT VARIABLES ----------
    vars.put(&quot;total_Onsite_Amount&quot;, onsiteTotal);
    vars.put(&quot;onsite_tot_amt&quot;, onsiteInvoiceTotal);
    vars.put(&quot;actual_GST&quot;, actualGST);
    vars.put(&quot;displaytotal_gst_amt&quot;, displayGST);
    vars.put(&quot;displaytotal_shift_amt&quot;, displayTotal);
    vars.put(&quot;onsiteErrorFlag&quot;, errorFlag);
    vars.put(&quot;onsiteErrorReason&quot;, errorReason);
}

log.info(&quot;---------- ONSITE CALCULATION END ----------&quot;);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="allowances" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// actually i defined super_amt is 0 

var response=JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;]
var allowanceinfo = data.invoice_allowances.length;
var tot_allowance = 0
var ac_gst = 0
var SA = 0
 for(var i = 0; i &lt; allowanceinfo; i++){

     var allow_type = data.invoice_allowances[i].allow_type
     
     if(allow_type == 2){
     	
 	var rate = data.invoice_allowances[i].rate
 	log.info(typeof rate)
 	var num_days = data.invoice_allowances[i].no_of_days
 	log.info(typeof num_days)
 	var amount = rate * num_days;
 	
 	log.info(&quot;amount is..&quot;+typeof amount)
 	tot_allowance = amount + tot_allowance;
 	log.info(&quot;tot_allowance is..&quot;+tot_allowance)
 	var gst = data.invoice_allowances[i].gst_tax_amt
 	gst = Number(gst)
 	log.info(&quot;gst is..&quot;+gst)
 	ac_gst = ac_gst + gst
 	log.info(&quot;ac_gst is..&quot;+ac_gst)
 	var sup_amt = data.invoice_allowances[i].sup_amt
 	sup_amt = Number(sup_amt)
 	log.info(&quot;sup_amt is..&quot;+sup_amt)
 	SA = SA + sup_amt
 	
     }
     if(allow_type == 3){

     var rate = data.invoice_allowances[i].rate
     log.info(&quot;rate in dayrate is..&quot;+rate)
 	tot_allowance = rate + tot_allowance;
 	log.info(&quot;tot_allowance dayrate is..&quot;+tot_allowance)
 	var gst = data.invoice_allowances[i].gst_tax_amt
 	gst = Number(gst)
 	log.info(&quot;gst dayrate is..&quot;+gst)
 	ac_gst = ac_gst + gst
 	log.info(&quot;ac_gst dayrate is..&quot;+ac_gst)
 	var sup_amt = data.invoice_allowances[i].sup_amt
 	sup_amt = Number(sup_amt)
 	log.info(&quot;sup_amt is..&quot;+sup_amt)
 	SA = SA + sup_amt
 	log.info(&quot;SA is..&quot;+SA)
     	
     	
     }
 }

vars.put(&quot;tot_allowance&quot;,tot_allowance)
log.info(&quot;tot_allowance is&quot; +typeof tot_allowance)
var allowance_gst = ac_gst
vars.put(&quot;allowance_gst&quot;,allowance_gst)
log.info(&quot;allowance_gst is&quot; +typeof allowance_gst)
var allowance_SA = SA
vars.put(&quot;allowance_SA&quot;,allowance_SA)
log.info(&quot;allowance_SA is&quot; +allowance_SA)
var inv_tot_allowance = tot_allowance - allowance_SA + allowance_gst
vars.put(&quot;inv_tot_allowance&quot;,inv_tot_allowance)
log.info(&quot;inv_tot_allowance is&quot; +typeof inv_tot_allowance)</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="modifications-chatgpt-e" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// --- Parse Response ---
var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

var mods = data.invoice_modifications;
var count = mods.length;

var totalModAmount = 0;     // sum of minus/plus
var totalModGST = 0;        // sum of minus/plus GST
var gstEnabled = Number(vars.get(&quot;gst&quot;)) === 1;

// Log count
log.info(&quot;Total Modification Records: &quot; + count);

// --- Helper function: GST ---
function calcGST(amount) {
    return gstEnabled ? (amount * 10) / 100 : 0;
}

// --- Loop modifications ---
for (var i = 0; i &lt; count; i++) {

    var mod = mods[i];
    var type = mod.type_id;
    var original = Number(mod.original_amount);

    var finalAmount = 0;
    var gstValue = 0;

   // comments check
    var anyModComments = &quot;NO&quot;;
    var mod_comments = &quot;&quot;;
    
    if (mod.approve_comments &amp;&amp; mod.approve_comments.trim() !== &quot;&quot;) {
    
        anyModComments = &quot;TRUE&quot;;
        mod_comments = mod.approve_comments
    }

    
    // Type 8 → Minus (-)
    // ---------------------------
    if (type === 8) {
        finalAmount = -original;                 // convert to negative
        gstValue = calcGST(finalAmount);         // GST also becomes negative

        log.info(&quot;[Minus] original=&quot; + original +
                 &quot; final=&quot; + finalAmount +
                 &quot; gst=&quot; + gstValue);
    }

    // ---------------------------
    // Type 7 → Plus (+)
    // ---------------------------
    else if (type === 7) {
        finalAmount = original;                  // positive
        gstValue = calcGST(finalAmount);

        log.info(&quot;[Plus] original=&quot; + original +
                 &quot; final=&quot; + finalAmount +
                 &quot; gst=&quot; + gstValue);
    }

    // ---------------------------
    // Other types
    // ---------------------------
    else {
        log.info(&quot;No modification for type: &quot; + type);
        continue;
    }

    // Accumulate totals
    totalModAmount += finalAmount;
    totalModGST += gstValue;
}

// --- Set Output Variables ---
vars.put(&quot;tot_modification_amount&quot;, totalModAmount);
vars.put(&quot;modification_gst&quot;, totalModGST);

var totalIncludingGST = totalModAmount + totalModGST;
vars.put(&quot;inv_tot_modification&quot;, totalIncludingGST);
vars.put(&quot;anyModComments&quot;,anyModComments)
vars.put(&quot;mod_comments&quot;,mod_comments)

log.info(&quot;anyModComments&quot;+anyModComments)
log.info(&quot;mod_comments&quot;+mod_comments)





// --- Logs ---
log.info(&quot;=== Final Modification Summary ===&quot;);
log.info(&quot;Total Modification Amount: &quot; + totalModAmount);
log.info(&quot;Total Modification GST: &quot; + totalModGST);
log.info(&quot;Total (Amount + GST): &quot; + totalIncludingGST);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="discount_invoice-chatgpt-e" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

// Lengths
var dis_shiftinfo         = data.invoice_generation_shifts.length;
var dis_cov_shifts        = data.invoice_generation_cov_shifts.length;
var dis_modificationinfo  = data.invoice_modifications.length;
var dis_allowanceinfo     = data.invoice_allowances.length;

vars.put(&quot;dis_shiftinfo&quot;, dis_shiftinfo);
vars.put(&quot;dis_cov_shifts&quot;, dis_cov_shifts);
vars.put(&quot;dis_modificationinfo&quot;, dis_modificationinfo);
vars.put(&quot;dis_allowanceinfo&quot;, dis_allowanceinfo);

// Discount %
var only_discount_inv_percentage = Number(data.discount_percentage);
vars.put(&quot;only_discount_inv_percentage&quot;, only_discount_inv_percentage);

// Final values
var discount_billing_total = 0;
var discount_gst_total = 0;
var discount_invoice_total = 0;

// Display values
var displayDiscountBillingTotal = Number(data.billing_total);
var displayDiscountGSTTotal = Number(data.gst_total);
var displayDiscountInvoiceTotal = Number(data.inv_total);

// ------------------------------------------------------------
//  FIXED CONDITION — This is the correct way
//  We check that *all* other items are 0 and only discount exists.
// ------------------------------------------------------------
if (
    dis_shiftinfo === 0 &amp;&amp;
    dis_modificationinfo === 0 &amp;&amp;
    dis_allowanceinfo === 0 &amp;&amp;
    only_discount_inv_percentage !== 0
) {
    //log.info(&quot;Only discount exists&quot;);

    // Find remaining percentage after discount
    var remainingPercentage = 100 - only_discount_inv_percentage;

    // --- Billing ---
    discount_billing_total = displayDiscountBillingTotal * (remainingPercentage / 100);

    // --- GST ---
    discount_gst_total = displayDiscountGSTTotal * (remainingPercentage / 100);

    // --- Invoice Total ---
    discount_invoice_total = displayDiscountInvoiceTotal * (remainingPercentage / 100);

   
}

// ------------------------------------------------------------
// Store final values
// ------------------------------------------------------------
vars.put(&quot;discount_billing_total&quot;, discount_billing_total);
vars.put(&quot;discount_gst_total&quot;, discount_gst_total);
vars.put(&quot;discount_invoice_total&quot;, discount_invoice_total);
vars.put(&quot;only_discount_inv_percentage&quot;, only_discount_inv_percentage);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="final_billing_total - chatgpt-e" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// Parse response
var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

// Display totals from API
var displaydiscount_billing_total = Number(data.billing_total);
var displaydiscount_gst_total = Number(data.gst_total);
var displaydiscount_inv_total = Number(data.inv_total);

// Counts
var dis_shiftinfo = Number(vars.get(&quot;dis_shiftinfo&quot;));
log.info(&quot;dis_shiftinfo is from final billing ..&quot;+dis_shiftinfo)
var dis_cov_shifts = Number(vars.get(&quot;dis_cov_shifts&quot;));
var dis_modificationinfo = Number(vars.get(&quot;dis_modificationinfo&quot;));
log.info(&quot;dis_modificationinfo is from final billing ..&quot;+dis_modificationinfo)
var dis_allowanceinfo = Number(vars.get(&quot;dis_allowanceinfo&quot;));
log.info(&quot;dis_allowanceinfo is from final billing ..&quot;+dis_allowanceinfo)
var only_discount_inv_percentage = Number(vars.get(&quot;only_discount_inv_percentage&quot;));

// Onsite values
var onsiteBillingTotal = Number(vars.get(&quot;onsiteBillingTotal&quot;));
log.info(&quot;onsiteBillingTotal is..&quot;+onsiteBillingTotal)
var onsiteSubTotal = Number(vars.get(&quot;onsiteSubTotal&quot;));
log.info(&quot;onsiteBillingTotal is..&quot;+onsiteBillingTotal)
var onsiteGST = Number(vars.get(&quot;onsiteGST&quot;));
log.info(&quot;onsiteGST is..&quot;+onsiteGST)
var onsiteInvoiceTot = Number(vars.get(&quot;onsiteInvoiceTot&quot;));
log.info(&quot;onsiteInvoiceTot is..&quot;+onsiteInvoiceTot)

// Allowances
var tot_allowance = Number(vars.get(&quot;tot_allowance&quot;));
var allowance_gst = Number(vars.get(&quot;allowance_gst&quot;));
var inv_tot_allowance = Number(vars.get(&quot;inv_tot_allowance&quot;));

// Modifications
var tot_modification_amount = Number(vars.get(&quot;tot_modification_amount&quot;));
log.info(&quot;tot_modification_amount is..&quot;+tot_modification_amount)
var modification_gst = Number(vars.get(&quot;modification_gst&quot;));
log.info(&quot;modification_gst is..&quot;+modification_gst)
var inv_tot_modification = Number(vars.get(&quot;inv_tot_modification&quot;));
log.info(&quot;inv_tot_modification is..&quot;+inv_tot_modification)


// Final expected totals
var exp_billing_total = 0;
var exp_sub_total = 0;
var exp_gst_total = 0;
var exp_invoice_total = 0;

// Discount percentage
var discount_percentage = Number(vars.get(&quot;discount_percentage&quot;));


// ***************************************************
// CASE 1: Shifts/mod/allowance exist &amp; NO discount
// ***************************************************
if ((dis_shiftinfo != 0 || dis_modificationinfo != 0 || dis_allowanceinfo != 0) &amp;&amp;
    only_discount_inv_percentage === 0)
{
	
    log.info(&quot;shifts/mod/allowance case executed&quot;);
    exp_billing_total = onsiteBillingTotal + tot_allowance + tot_modification_amount;
    exp_sub_total = onsiteSubTotal + tot_allowance + tot_modification_amount;
    exp_gst_total = onsiteGST + allowance_gst + modification_gst;
    exp_invoice_total = onsiteInvoiceTot + inv_tot_allowance + inv_tot_modification;
    
}


// ***************************************************
// CASE 2: Shifts/mod/allowance exist + discount applied
// ***************************************************
else if ((dis_shiftinfo != 0 || dis_modificationinfo != 0 || dis_allowanceinfo != 0) &amp;&amp;
         only_discount_inv_percentage !== 0)
{
    log.info(&quot;Discount + shifts/mod/allowance case executed&quot;);

    var remainingPercentage = 100 - discount_percentage;

    exp_billing_total = (onsiteBillingTotal + tot_allowance) * remainingPercentage / 100;
    exp_sub_total = (onsiteSubTotal + tot_allowance) * remainingPercentage / 100;
    exp_gst_total = (onsiteGST + allowance_gst) * remainingPercentage / 100;
    exp_invoice_total = (onsiteInvoiceTot + inv_tot_allowance) * remainingPercentage / 100;
}


// ***************************************************
// CASE 3: Only pure discount scenario (no shift/mod/allowances)
// ***************************************************
else {
    log.info(&quot;Only discount block executed&quot;);

    exp_billing_total = Number(vars.get(&quot;discount_billing_total&quot;));
    
    exp_gst_total = Number(vars.get(&quot;discount_gst_total&quot;));
    exp_invoice_total = Number(vars.get(&quot;discount_invoice_total&quot;));
}


// ***************************************************
// DISCOUNT ERROR CHECKS
// ***************************************************
var discountBillingAmountDiff = Math.abs(exp_billing_total - displaydiscount_billing_total);
var discountGSTAmountDiff = Math.abs(exp_gst_total - displaydiscount_gst_total);
var discountInvoiceAmountDiff = Math.abs(exp_invoice_total - displaydiscount_inv_total);

var discountErrorFlag = &quot;FALSE&quot;;
var discountErrorReason = &quot;&quot;;

if (only_discount_inv_percentage !== 0)
{
    if (discountBillingAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount Billing Amount Mismatch&quot;;
    }
    else if (discountGSTAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount GST Amount Mismatch&quot;;
    }
    else if (discountInvoiceAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount Invoice Total Mismatch&quot;;
    }
}

vars.put(&quot;discountErrorFlag&quot;, discountErrorFlag);
vars.put(&quot;discountErrorReason&quot;, discountErrorReason);




// ***************************************************
// NULL CHECK
// ***************************************************
var nullFlag = &quot;FALSE&quot;;
var nullError = &quot;&quot;;

if (exp_billing_total !== exp_billing_total || exp_invoice_total !== exp_invoice_total)
{
    nullFlag = &quot;TRUE&quot;;
    nullError = &quot;Please check invoice manually&quot;;
}

vars.put(&quot;nullFlag&quot;, nullFlag);
vars.put(&quot;nullError&quot;, nullError);


// ***************************************************
// ACTUAL VALUES (from API invoice)
// ***************************************************
var act_billing_total = Number(vars.get(&quot;act_billing_total&quot;));
var act_gst_total = Number(vars.get(&quot;act_gst_total&quot;));
var act_inv_total = Number(vars.get(&quot;act_inv_total&quot;));

var num = Math.abs(act_inv_total - exp_invoice_total);


// ***************************************************
// FINAL ERROR COMBINATION
// ***************************************************
var errorReason = &quot;&quot;;
var onsiteErrorCause = vars.get(&quot;onsiteErrorReason&quot;);
var discountErrorCause = vars.get(&quot;discountErrorReason&quot;);

if (onsiteErrorCause == &quot;TRUE&quot; || discountErrorFlag == &quot;TRUE&quot; || nullFlag == &quot;TRUE&quot;)
{
    errorReason = onsiteErrorCause + &quot;-&quot; + discountErrorCause +&quot;-&quot; +nullError;
}

errorReason = errorReason.replace(/undefined-/g, &quot; &quot;);
errorReason = errorReason.replace(/-undefined/g, &quot; &quot;);
vars.put(&quot;errorReason&quot;, errorReason);
log.info(&quot;errorReason is..&quot;+errorReason)


// ***************************************************
// FINAL RESULT
// ***************************************************
var testResult = &quot;PASS&quot;;

if (num &gt; 1 || exp_invoice_total !== exp_invoice_total)
{
    testResult = &quot;FAIL&quot;;
}


vars.put(&quot;exp_billing_total&quot;,exp_billing_total)
vars.put(&quot;exp_sub_total&quot;,exp_sub_total)
vars.put(&quot;exp_gst_total&quot;,exp_gst_total)
vars.put(&quot;exp_invoice_total&quot;,exp_invoice_total)

vars.put(&quot;testResult&quot;, testResult);

log.info(&quot;testResult is: &quot; + testResult);
log.info(&quot;Exp_Billing_Total: &quot; + exp_billing_total);
log.info(&quot;Exp_GST_Total: &quot; + exp_gst_total);
log.info(&quot;Exp_Invoice_Total: &quot; + exp_invoice_total);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                </hashTree>
                <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="shiftinformation-${invoiceId}" enabled="false">
                  <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
                  <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                    <collectionProp name="Arguments.arguments">
                      <elementProp name="" elementType="HTTPArgument">
                        <boolProp name="HTTPArgument.always_encode">false</boolProp>
                        <stringProp name="Argument.value">{&#xd;
  &quot;invoice_id&quot;: &quot;${invoiceId}&quot;,&#xd;
  &quot;hid&quot;: 226,&#xd;
  &quot;decimalCalObj&quot;: {&#xd;
    &quot;hid&quot;: 226,&#xd;
    &quot;isRoundOff&quot;: 1,&#xd;
    &quot;decimalCnt&quot;: 2,&#xd;
    &quot;displayDecimalCnt&quot;: 2,&#xd;
    &quot;display_sign_off&quot;: 1&#xd;
  }&#xd;
}</stringProp>
                        <stringProp name="Argument.metadata">=</stringProp>
                      </elementProp>
                    </collectionProp>
                  </elementProp>
                  <stringProp name="HTTPSampler.domain"></stringProp>
                  <stringProp name="HTTPSampler.port"></stringProp>
                  <stringProp name="HTTPSampler.protocol"></stringProp>
                  <stringProp name="HTTPSampler.contentEncoding"></stringProp>
                  <stringProp name="HTTPSampler.path">modpay-node/mm/invoice/view_invoice</stringProp>
                  <stringProp name="HTTPSampler.method">POST</stringProp>
                  <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                  <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
                  <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
                  <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
                  <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
