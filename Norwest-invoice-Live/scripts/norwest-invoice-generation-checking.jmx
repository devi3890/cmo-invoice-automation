                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="allowances" enabled="false">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// actually i defined super_amt is 0 

var response=JSON.parse(prev.getResponseDataAsString())
var data = response[&quot;data&quot;]
var allowanceinfo = data.invoice_allowances.length;
var tot_allowance = 0
var ac_gst = 0
var SA = 0
 for(var i = 0; i &lt; allowanceinfo; i++){

     var allow_type = data.invoice_allowances[i].allow_type
     
     if(allow_type == 2){
     	
 	var rate = data.invoice_allowances[i].rate
 	log.info(typeof rate)
 	var num_days = data.invoice_allowances[i].no_of_days
 	log.info(typeof num_days)
 	var amount = rate * num_days;
 	
 	log.info(&quot;amount is..&quot;+typeof amount)
 	tot_allowance = amount + tot_allowance;
 	log.info(&quot;tot_allowance is..&quot;+tot_allowance)
 	var gst = data.invoice_allowances[i].gst_tax_amt
 	gst = Number(gst)
 	log.info(&quot;gst is..&quot;+gst)
 	ac_gst = ac_gst + gst
 	log.info(&quot;ac_gst is..&quot;+ac_gst)
 	var sup_amt = data.invoice_allowances[i].sup_amt
 	sup_amt = Number(sup_amt)
 	log.info(&quot;sup_amt is..&quot;+sup_amt)
 	SA = SA + sup_amt
 	
     }
     if(allow_type == 3){

     var rate = data.invoice_allowances[i].rate
     log.info(&quot;rate in dayrate is..&quot;+rate)
 	tot_allowance = rate + tot_allowance;
 	log.info(&quot;tot_allowance dayrate is..&quot;+tot_allowance)
 	var gst = data.invoice_allowances[i].gst_tax_amt
 	gst = Number(gst)
 	log.info(&quot;gst dayrate is..&quot;+gst)
 	ac_gst = ac_gst + gst
 	log.info(&quot;ac_gst dayrate is..&quot;+ac_gst)
 	var sup_amt = data.invoice_allowances[i].sup_amt
 	sup_amt = Number(sup_amt)
 	log.info(&quot;sup_amt is..&quot;+sup_amt)
 	SA = SA + sup_amt
 	log.info(&quot;SA is..&quot;+SA)
     	
     	
     }
 }

vars.put(&quot;tot_allowance&quot;,tot_allowance)
log.info(&quot;tot_allowance is&quot; +typeof tot_allowance)
var allowance_gst = ac_gst
vars.put(&quot;allowance_gst&quot;,allowance_gst)
log.info(&quot;allowance_gst is&quot; +typeof allowance_gst)
var allowance_SA = SA
vars.put(&quot;allowance_SA&quot;,allowance_SA)
log.info(&quot;allowance_SA is&quot; +allowance_SA)
var inv_tot_allowance = tot_allowance - allowance_SA + allowance_gst
vars.put(&quot;inv_tot_allowance&quot;,inv_tot_allowance)
log.info(&quot;inv_tot_allowance is&quot; +typeof inv_tot_allowance)</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="modifications-chatgpt-e" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// --- Parse Response ---
var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

var mods = data.invoice_modifications;
var count = mods.length;

var totalModAmount = 0;     // sum of minus/plus
var totalModGST = 0;        // sum of minus/plus GST
var gstEnabled = Number(vars.get(&quot;gst&quot;)) === 1;

// Log count
log.info(&quot;Total Modification Records: &quot; + count);

// --- Helper function: GST ---
function calcGST(amount) {
    return gstEnabled ? (amount * 10) / 100 : 0;
}

// --- Loop modifications ---
for (var i = 0; i &lt; count; i++) {

    var mod = mods[i];
    var type = mod.type_id;
    var original = Number(mod.original_amount);

    var finalAmount = 0;
    var gstValue = 0;

   // comments check
    var anyModComments = &quot;NO&quot;;
    var mod_comments = &quot;&quot;;
    
    if (mod.approve_comments &amp;&amp; mod.approve_comments.trim() !== &quot;&quot;) {
    
        anyModComments = &quot;TRUE&quot;;
        mod_comments = mod.approve_comments
    }

    
    // Type 8 → Minus (-)
    // ---------------------------
    if (type === 8) {
        finalAmount = -original;                 // convert to negative
        gstValue = calcGST(finalAmount);         // GST also becomes negative

        log.info(&quot;[Minus] original=&quot; + original +
                 &quot; final=&quot; + finalAmount +
                 &quot; gst=&quot; + gstValue);
    }

    // ---------------------------
    // Type 7 → Plus (+)
    // ---------------------------
    else if (type === 7) {
        finalAmount = original;                  // positive
        gstValue = calcGST(finalAmount);

        log.info(&quot;[Plus] original=&quot; + original +
                 &quot; final=&quot; + finalAmount +
                 &quot; gst=&quot; + gstValue);
    }

    // ---------------------------
    // Other types
    // ---------------------------
    else {
        log.info(&quot;No modification for type: &quot; + type);
        continue;
    }

    // Accumulate totals
    totalModAmount += finalAmount;
    totalModGST += gstValue;
}

// --- Set Output Variables ---
vars.put(&quot;tot_modification_amount&quot;, totalModAmount);
vars.put(&quot;modification_gst&quot;, totalModGST);

var totalIncludingGST = totalModAmount + totalModGST;
vars.put(&quot;inv_tot_modification&quot;, totalIncludingGST);
vars.put(&quot;anyModComments&quot;,anyModComments)
vars.put(&quot;mod_comments&quot;,mod_comments)

log.info(&quot;anyModComments&quot;+anyModComments)
log.info(&quot;mod_comments&quot;+mod_comments)





// --- Logs ---
log.info(&quot;=== Final Modification Summary ===&quot;);
log.info(&quot;Total Modification Amount: &quot; + totalModAmount);
log.info(&quot;Total Modification GST: &quot; + totalModGST);
log.info(&quot;Total (Amount + GST): &quot; + totalIncludingGST);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="discount_invoice-chatgpt-e" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

// Lengths
var dis_shiftinfo         = data.invoice_generation_shifts.length;
var dis_cov_shifts        = data.invoice_generation_cov_shifts.length;
var dis_modificationinfo  = data.invoice_modifications.length;
var dis_allowanceinfo     = data.invoice_allowances.length;

vars.put(&quot;dis_shiftinfo&quot;, dis_shiftinfo);
vars.put(&quot;dis_cov_shifts&quot;, dis_cov_shifts);
vars.put(&quot;dis_modificationinfo&quot;, dis_modificationinfo);
vars.put(&quot;dis_allowanceinfo&quot;, dis_allowanceinfo);

// Discount %
var only_discount_inv_percentage = Number(data.discount_percentage);
vars.put(&quot;only_discount_inv_percentage&quot;, only_discount_inv_percentage);

// Final values
var discount_billing_total = 0;
var discount_gst_total = 0;
var discount_invoice_total = 0;

// Display values
var displayDiscountBillingTotal = Number(data.billing_total);
var displayDiscountGSTTotal = Number(data.gst_total);
var displayDiscountInvoiceTotal = Number(data.inv_total);

// ------------------------------------------------------------
//  FIXED CONDITION — This is the correct way
//  We check that *all* other items are 0 and only discount exists.
// ------------------------------------------------------------
if (
    dis_shiftinfo === 0 &amp;&amp;
    dis_modificationinfo === 0 &amp;&amp;
    dis_allowanceinfo === 0 &amp;&amp;
    only_discount_inv_percentage !== 0
) {
    //log.info(&quot;Only discount exists&quot;);

    // Find remaining percentage after discount
    var remainingPercentage = 100 - only_discount_inv_percentage;

    // --- Billing ---
    discount_billing_total = displayDiscountBillingTotal * (remainingPercentage / 100);

    // --- GST ---
    discount_gst_total = displayDiscountGSTTotal * (remainingPercentage / 100);

    // --- Invoice Total ---
    discount_invoice_total = displayDiscountInvoiceTotal * (remainingPercentage / 100);

   
}

// ------------------------------------------------------------
// Store final values
// ------------------------------------------------------------
vars.put(&quot;discount_billing_total&quot;, discount_billing_total);
vars.put(&quot;discount_gst_total&quot;, discount_gst_total);
vars.put(&quot;discount_invoice_total&quot;, discount_invoice_total);
vars.put(&quot;only_discount_inv_percentage&quot;, only_discount_inv_percentage);
</stringProp>
                  </JSR223PostProcessor>
                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="final_billing_total - chatgpt-e" enabled="true">
                    <stringProp name="scriptLanguage">javascript</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">// Parse response
var response = JSON.parse(prev.getResponseDataAsString());
var data = response[&quot;data&quot;];

// Display totals from API
var displaydiscount_billing_total = Number(data.billing_total);
var displaydiscount_gst_total = Number(data.gst_total);
var displaydiscount_inv_total = Number(data.inv_total);

// Counts
var dis_shiftinfo = Number(vars.get(&quot;dis_shiftinfo&quot;));
log.info(&quot;dis_shiftinfo is from final billing ..&quot;+dis_shiftinfo)
var dis_cov_shifts = Number(vars.get(&quot;dis_cov_shifts&quot;));
var dis_modificationinfo = Number(vars.get(&quot;dis_modificationinfo&quot;));
log.info(&quot;dis_modificationinfo is from final billing ..&quot;+dis_modificationinfo)
var dis_allowanceinfo = Number(vars.get(&quot;dis_allowanceinfo&quot;));
log.info(&quot;dis_allowanceinfo is from final billing ..&quot;+dis_allowanceinfo)
var only_discount_inv_percentage = Number(vars.get(&quot;only_discount_inv_percentage&quot;));

// Onsite values
var onsiteBillingTotal = Number(vars.get(&quot;onsiteBillingTotal&quot;));
log.info(&quot;onsiteBillingTotal is..&quot;+onsiteBillingTotal)
var onsiteSubTotal = Number(vars.get(&quot;onsiteSubTotal&quot;));
log.info(&quot;onsiteBillingTotal is..&quot;+onsiteBillingTotal)
var onsiteGST = Number(vars.get(&quot;onsiteGST&quot;));
log.info(&quot;onsiteGST is..&quot;+onsiteGST)
var onsiteInvoiceTot = Number(vars.get(&quot;onsiteInvoiceTot&quot;));
log.info(&quot;onsiteInvoiceTot is..&quot;+onsiteInvoiceTot)

// Allowances
var tot_allowance = Number(vars.get(&quot;tot_allowance&quot;));
var allowance_gst = Number(vars.get(&quot;allowance_gst&quot;));
var inv_tot_allowance = Number(vars.get(&quot;inv_tot_allowance&quot;));

// Modifications
var tot_modification_amount = Number(vars.get(&quot;tot_modification_amount&quot;));
log.info(&quot;tot_modification_amount is..&quot;+tot_modification_amount)
var modification_gst = Number(vars.get(&quot;modification_gst&quot;));
log.info(&quot;modification_gst is..&quot;+modification_gst)
var inv_tot_modification = Number(vars.get(&quot;inv_tot_modification&quot;));
log.info(&quot;inv_tot_modification is..&quot;+inv_tot_modification)


// Final expected totals
var exp_billing_total = 0;
var exp_sub_total = 0;
var exp_gst_total = 0;
var exp_invoice_total = 0;

// Discount percentage
var discount_percentage = Number(vars.get(&quot;discount_percentage&quot;));


// ***************************************************
// CASE 1: Shifts/mod/allowance exist &amp; NO discount
// ***************************************************
if ((dis_shiftinfo != 0 || dis_modificationinfo != 0 || dis_allowanceinfo != 0) &amp;&amp;
    only_discount_inv_percentage === 0)
{
	
    log.info(&quot;shifts/mod/allowance case executed&quot;);
    exp_billing_total = onsiteBillingTotal + tot_allowance + tot_modification_amount;
    exp_sub_total = onsiteSubTotal + tot_allowance + tot_modification_amount;
    exp_gst_total = onsiteGST + allowance_gst + modification_gst;
    exp_invoice_total = onsiteInvoiceTot + inv_tot_allowance + inv_tot_modification;
    
}


// ***************************************************
// CASE 2: Shifts/mod/allowance exist + discount applied
// ***************************************************
else if ((dis_shiftinfo != 0 || dis_modificationinfo != 0 || dis_allowanceinfo != 0) &amp;&amp;
         only_discount_inv_percentage !== 0)
{
    log.info(&quot;Discount + shifts/mod/allowance case executed&quot;);

    var remainingPercentage = 100 - discount_percentage;

    exp_billing_total = (onsiteBillingTotal + tot_allowance) * remainingPercentage / 100;
    exp_sub_total = (onsiteSubTotal + tot_allowance) * remainingPercentage / 100;
    exp_gst_total = (onsiteGST + allowance_gst) * remainingPercentage / 100;
    exp_invoice_total = (onsiteInvoiceTot + inv_tot_allowance) * remainingPercentage / 100;
}


// ***************************************************
// CASE 3: Only pure discount scenario (no shift/mod/allowances)
// ***************************************************
else {
    log.info(&quot;Only discount block executed&quot;);

    exp_billing_total = Number(vars.get(&quot;discount_billing_total&quot;));
    
    exp_gst_total = Number(vars.get(&quot;discount_gst_total&quot;));
    exp_invoice_total = Number(vars.get(&quot;discount_invoice_total&quot;));
}


// ***************************************************
// DISCOUNT ERROR CHECKS
// ***************************************************
var discountBillingAmountDiff = Math.abs(exp_billing_total - displaydiscount_billing_total);
var discountGSTAmountDiff = Math.abs(exp_gst_total - displaydiscount_gst_total);
var discountInvoiceAmountDiff = Math.abs(exp_invoice_total - displaydiscount_inv_total);

var discountErrorFlag = &quot;FALSE&quot;;
var discountErrorReason = &quot;&quot;;

if (only_discount_inv_percentage !== 0)
{
    if (discountBillingAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount Billing Amount Mismatch&quot;;
    }
    else if (discountGSTAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount GST Amount Mismatch&quot;;
    }
    else if (discountInvoiceAmountDiff &gt; 0.8) {
        discountErrorFlag = &quot;TRUE&quot;;
        discountErrorReason = &quot;Discount Invoice Total Mismatch&quot;;
    }
}

vars.put(&quot;discountErrorFlag&quot;, discountErrorFlag);
vars.put(&quot;discountErrorReason&quot;, discountErrorReason);




// ***************************************************
// NULL CHECK
// ***************************************************
var nullFlag = &quot;FALSE&quot;;
var nullError = &quot;&quot;;

if (exp_billing_total !== exp_billing_total || exp_invoice_total !== exp_invoice_total)
{
    nullFlag = &quot;TRUE&quot;;
    nullError = &quot;Please check invoice manually&quot;;
}

vars.put(&quot;nullFlag&quot;, nullFlag);
vars.put(&quot;nullError&quot;, nullError);


// ***************************************************
// ACTUAL VALUES (from API invoice)
// ***************************************************
var act_billing_total = Number(vars.get(&quot;act_billing_total&quot;));
var act_gst_total = Number(vars.get(&quot;act_gst_total&quot;));
var act_inv_total = Number(vars.get(&quot;act_inv_total&quot;));

var num = Math.abs(act_inv_total - exp_invoice_total);


// ***************************************************
// FINAL ERROR COMBINATION
// ***************************************************
var errorReason = &quot;&quot;;
var onsiteErrorCause = vars.get(&quot;onsiteErrorReason&quot;);
var discountErrorCause = vars.get(&quot;discountErrorReason&quot;);

if (onsiteErrorCause == &quot;TRUE&quot; || discountErrorFlag == &quot;TRUE&quot; || nullFlag == &quot;TRUE&quot;)
{
    errorReason = onsiteErrorCause + &quot;-&quot; + discountErrorCause +&quot;-&quot; +nullError;
}

errorReason = errorReason.replace(/undefined-/g, &quot; &quot;);
errorReason = errorReason.replace(/-undefined/g, &quot; &quot;);
vars.put(&quot;errorReason&quot;, errorReason);
log.info(&quot;errorReason is..&quot;+errorReason)


// ***************************************************
// FINAL RESULT
// ***************************************************
var testResult = &quot;PASS&quot;;

if (num &gt; 1 || exp_invoice_total !== exp_invoice_total)
{
    testResult = &quot;FAIL&quot;;
}


vars.put(&quot;exp_billing_total&quot;,exp_billing_total)
vars.put(&quot;exp_sub_total&quot;,exp_sub_total)
vars.put(&quot;exp_gst_total&quot;,exp_gst_total)
vars.put(&quot;exp_invoice_total&quot;,exp_invoice_total)

vars.put(&quot;testResult&quot;, testResult);

log.info(&quot;testResult is: &quot; + testResult);
log.info(&quot;Exp_Billing_Total: &quot; + exp_billing_total);
log.info(&quot;Exp_GST_Total: &quot; + exp_gst_total);
log.info(&quot;Exp_Invoice_Total: &quot; + exp_invoice_total);
</stringProp>
                  </JSR223PostProcessor>
